#include <stdio.h>
#include <stdlib.h>

struct Bank
{
    int accNo;
    char name[50];
    float balance;
};

void deposit();
void withdraw();
void balanceEnquiry();

int main()
{
    int choice;

    while (1)
    {
        printf("\n========== BANK ACCOUNT MANAGEMENT SYSTEM ==========\n");
        printf("1. Deposit\n");
        printf("2. Withdraw\n");
        printf("3. Balance Enquiry\n");
        printf("4. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice)
        {
        case 1:
            deposit();
            break;

        case 2:
            withdraw();
            break;

        case 3:
            balanceEnquiry();
            break;

        case 4:
            printf("Thank you for using our banking system.\n");
            exit(0);

        default:
            printf("Invalid Choice!\n");
        }
    }

    return 0;
}

void deposit()
{
    struct Bank b;
    FILE *fp;

    fp = fopen("bank.dat", "rb");

    if (fp == NULL)
    {
        printf("\nCreating New Account...\n");
        printf("Enter Account Number: ");
        scanf("%d", &b.accNo);

        printf("Enter Name: ");
        scanf("%s", b.name);

        printf("Enter Initial Deposit: ");
        scanf("%f", &b.balance);

        fp = fopen("bank.dat", "wb");
        fwrite(&b, sizeof(b), 1, fp);
        fclose(fp);

        printf("Account Created Successfully!\n");
    }
    else
    {
        fread(&b, sizeof(b), 1, fp);
        fclose(fp);

        float amount;
        printf("Enter Deposit Amount: ");
        scanf("%f", &amount);

        b.balance += amount;

        fp = fopen("bank.dat", "wb");
        fwrite(&b, sizeof(b), 1, fp);
        fclose(fp);

        printf("Deposit Successful!\n");
    }
}

void withdraw()
{
    struct Bank b;
    FILE *fp;

    fp = fopen("bank.dat", "rb");

    if (fp == NULL)
    {
        printf("No Account Found!\n");
        return;
    }

    fread(&b, sizeof(b), 1, fp);
    fclose(fp);

    float amount;

    printf("Enter Withdrawal Amount: ");
    scanf("%f", &amount);

    if (amount > b.balance)
    {
        printf("Insufficient Balance!\n");
    }
    else
    {
        b.balance -= amount;

        fp = fopen("bank.dat", "wb");
        fwrite(&b, sizeof(b), 1, fp);
        fclose(fp);

        printf("Withdrawal Successful!\n");
    }
}

void balanceEnquiry()
{
    struct Bank b;
    FILE *fp;

    fp = fopen("bank.dat", "rb");

    if (fp == NULL)
    {
        printf("No Account Found!\n");
        return;
    }

    fread(&b, sizeof(b), 1, fp);
    fclose(fp);

    printf("\n------ ACCOUNT DETAILS ------\n");
    printf("Account Number : %d\n", b.accNo);
    printf("Account Holder : %s\n", b.name);
    printf("Current Balance: %.2f\n", b.balance);
}
